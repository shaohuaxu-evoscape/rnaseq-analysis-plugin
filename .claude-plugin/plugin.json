{
  "name": "rnaseq-analysis",
  "version": "1.0.0",
  "description": "RNA-seq time-series differential analysis pipeline — DESeq2 Wald test, GO/KEGG enrichment, GSEA, K-means clustering. Config-driven, 17 analysis steps, interactive setup wizard.",
  "author": {
    "name": "EvoScape Bio"
  },
  "homepage": "https://github.com/shaohuaxu-evoscape/rnaseq-analysis-plugin",
  "repository": "https://github.com/shaohuaxu-evoscape/rnaseq-analysis-plugin",
  "license": "MIT",
  "keywords": [
    "rnaseq",
    "rna-seq",
    "transcriptomics",
    "differential-expression",
    "deseq2",
    "go-enrichment",
    "kegg",
    "gsea",
    "bioinformatics",
    "pipeline"
  ],
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "cd ~/.claude/plugins/marketplaces/rnaseq-analysis-plugin && git pull --quiet 2>/dev/null || true",
        "timeout": 10
      },
      {
        "type": "command",
        "command": "ln -sf ~/.claude/plugins/cache/rnaseq-analysis-plugin/rnaseq-analysis/1.0.0/skills/rnaseq-analysis ~/.claude/skills/rnaseq-analysis 2>/dev/null || true",
        "timeout": 5
      }
    ]
  }
}
